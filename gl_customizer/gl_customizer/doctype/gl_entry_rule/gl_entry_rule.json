{
	"name": "GL Entry Rule",
	"doctype": "DocType",
	"module": "GL Customizer",
	"autoname": "field:rule_name",
	"document_type": "Setup",
	"engine": "InnoDB",
	"field_order": [
		"rule_name",
		"enabled",
		"column_break_source",
		"source_doctype",
		"company",
		"priority",
		"section_break_condition",
		"condition",
		"section_break_suppress",
		"suppress_default_entries",
		"section_break_override",
		"enable_account_overrides",
		"suppress_filters",
		"section_break_entries",
		"enable_custom_entries",
		"entry_lines"
	],
	"fields": [
		{
			"fieldname": "rule_name",
			"fieldtype": "Data",
			"label": "Rule Name",
			"reqd": 1,
			"unique": 1
		},
		{
			"fieldname": "enabled",
			"fieldtype": "Check",
			"label": "Enabled",
			"default": "1"
		},
		{
			"fieldname": "column_break_source",
			"fieldtype": "Column Break"
		},
		{
			"fieldname": "source_doctype",
			"fieldtype": "Select",
			"label": "Source Document Type",
			"options": "\nPurchase Invoice\nSales Invoice\nDelivery Note",
			"reqd": 1,
			"in_list_view": 1,
			"in_standard_filter": 1
		},
		{
			"fieldname": "company",
			"fieldtype": "Link",
			"label": "Company",
			"options": "Company",
			"description": "Leave blank to apply to all companies"
		},
		{
			"fieldname": "priority",
			"fieldtype": "Int",
			"label": "Priority",
			"default": "0",
			"description": "Higher priority rules execute first"
		},
		{
			"fieldname": "section_break_condition",
			"fieldtype": "Section Break",
			"label": "Condition"
		},
		{
			"fieldname": "condition",
			"fieldtype": "Small Text",
			"label": "Condition",
			"description": "Python expression. Rule applies only when this evaluates to True. Leave blank to always apply. Available: doc, flt, cint, abs. Example: doc.supplier_group == 'Import'"
		},
		{
			"fieldname": "section_break_suppress",
			"fieldtype": "Section Break",
			"label": "Suppress Default Entries"
		},
		{
			"fieldname": "suppress_default_entries",
			"fieldtype": "Check",
			"label": "Suppress All Default GL Entries",
			"description": "If checked, ALL default GL entries from ERPNext will be removed. Custom entry lines below are added separately."
		},
		{
			"fieldname": "section_break_override",
			"fieldtype": "Section Break",
			"label": "Override Default Entry Accounts"
		},
		{
			"fieldname": "enable_account_overrides",
			"fieldtype": "Check",
			"label": "Enable Account Overrides",
			"description": "Replace accounts on matching default GL entries. Amounts are kept unchanged.",
			"depends_on": "eval:!doc.suppress_default_entries"
		},
		{
			"fieldname": "suppress_filters",
			"fieldtype": "Table",
			"label": "Account Override Rules",
			"options": "GL Entry Suppress Filter",
			"depends_on": "eval:doc.enable_account_overrides && !doc.suppress_default_entries",
			"mandatory_depends_on": "eval:doc.enable_account_overrides && !doc.suppress_default_entries",
			"description": "Replace accounts on matching default GL entries. Amounts are kept unchanged."
		},
		{
			"fieldname": "section_break_entries",
			"fieldtype": "Section Break",
			"label": "Custom GL Entry Lines"
		},
		{
			"fieldname": "enable_custom_entries",
			"fieldtype": "Check",
			"label": "Enable Custom GL Entries",
			"description": "Add custom GL entries. Total debit must equal total credit across all lines."
		},
		{
			"fieldname": "entry_lines",
			"fieldtype": "Table",
			"label": "Entry Lines",
			"options": "GL Entry Rule Line",
			"depends_on": "eval:doc.enable_custom_entries",
			"mandatory_depends_on": "eval:doc.enable_custom_entries",
			"description": "Define custom GL entries. Total debit must equal total credit across all lines."
		}
	],
	"permissions": [
		{
			"role": "Accounts Manager",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 1
		},
		{
			"role": "System Manager",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 1
		}
	],
	"sort_field": "priority",
	"sort_order": "DESC",
	"track_changes": 1
}
