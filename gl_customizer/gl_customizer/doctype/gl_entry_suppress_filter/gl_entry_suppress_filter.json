{
	"name": "GL Entry Suppress Filter",
	"doctype": "DocType",
	"module": "GL Customizer",
	"istable": 1,
	"editable_grid": 1,
	"engine": "InnoDB",
	"field_order": [
		"account_contains",
		"side",
		"column_break_replace",
		"replacement_account"
	],
	"fields": [
		{
			"fieldname": "account_contains",
			"fieldtype": "Data",
			"label": "Account Contains",
			"reqd": 1,
			"in_list_view": 1,
			"description": "Match default GL entries where the account name contains this string"
		},
		{
			"fieldname": "side",
			"fieldtype": "Select",
			"label": "Side",
			"options": "Both\nDebit\nCredit",
			"default": "Both",
			"reqd": 1,
			"in_list_view": 1,
			"description": "Which side of the entry to match"
		},
		{
			"fieldname": "column_break_replace",
			"fieldtype": "Column Break"
		},
		{
			"fieldname": "replacement_account",
			"fieldtype": "Link",
			"label": "Replacement Account",
			"options": "Account",
			"reqd": 1,
			"in_list_view": 1,
			"description": "Replace the matched account with this account. Amounts are kept unchanged."
		}
	],
	"permissions": [],
	"sort_field": "creation",
	"sort_order": "ASC"
}
